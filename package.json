{
  "name": "slidedev-figma-plugin",
  "version": "1.0.0",
  "description": "Figma plugin to export designs to SlideDev",
  "main": "dist/code.js",
  "scripts": {
    "build": "esbuild code.ts --bundle --outfile=dist/code.js --target=es2017 && copy ui.html dist\\ui.html",
    "watch": "esbuild code.ts --bundle --outfile=dist/code.js --target=es2017 --watch"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.98.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}